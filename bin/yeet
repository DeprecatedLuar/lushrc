#!/usr/bin/env bash
# yeet - send files to remote machines

set -euo pipefail

LIBDIR="${LIBDIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/lib" && pwd)}"
source "$LIBDIR/shared/net.sh"
source "$LIBDIR/shared/spinner.sh"

REMOVE_SOURCE=false
SKIP_CONFIRM=false
DEBUG=false
NAV_FLAGS=""
CONN_USER=""
CONN_HOST=""
CONN_PORT=""
FLAG_PORT=""

show_help() {
    echo "Usage: yeet [OPTIONS] local_source [user@]host[:port] [remote_path]"
    echo ""
    echo "Send files to remote machines using rsync over SSH."
    echo ""
    echo "Options:"
    echo "  -h, --help          Show this help message"
    echo "  --rm                Remove source files after transfer"
    echo "  -y, --yes           Skip confirmation prompt"
    echo "  --debug             Enable debug output (path resolution)"
    echo "  -p PORT             SSH port (can also use host:port syntax)"
    echo "  -l USER             SSH user (can also use user@host syntax)"
    echo ""
    echo "Examples:"
    echo "  yeet file.txt nuremberg              # send to remote \$HOME"
    echo "  yeet backup.db .17:8022              # send to LAN host"
    echo "  yeet project/ vps d/backups          # nav-engine remote path"
    echo "  yeet --rm data.sql server w/data     # send and delete local source"
    echo "  yeet --debug data.db .17 ~/backups   # debug path resolution"
    exit 0
}

POSITIONALS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)      show_help ;;
        --rm)           REMOVE_SOURCE=true; shift ;;
        -y|--yes)       SKIP_CONFIRM=true; shift ;;
        --debug)        DEBUG=true; NAV_FLAGS="--debug"; shift ;;
        -p)             FLAG_PORT="$2"; shift 2 ;;
        -l)             CONN_USER="$2"; shift 2 ;;
        -*)             echo "Unknown option: $1" >&2; exit 1 ;;
        *)              POSITIONALS+=("$1"); shift ;;
    esac
done
set -- "${POSITIONALS[@]}"

if [[ $# -lt 2 ]]; then
    show_help
fi

LOCAL_SOURCE="$1"

# --- Normalize host ---
local_input="$2"
if [[ "$local_input" == *@* ]]; then
    CONN_USER="${local_input%%@*}"
    local_input="${local_input#*@}"
fi
if [[ "$local_input" == *:* ]]; then
    COLON_PORT="${local_input##*:}"
    CONN_HOST="${local_input%:*}"
    if [[ -n "$FLAG_PORT" && "$FLAG_PORT" != "$COLON_PORT" ]]; then
        echo "Error: conflicting ports (-p $FLAG_PORT vs :$COLON_PORT)" >&2
        exit 1
    fi
    CONN_PORT="$COLON_PORT"
else
    CONN_HOST="$local_input"
fi
[[ -n "$FLAG_PORT" && -z "$CONN_PORT" ]] && CONN_PORT="$FLAG_PORT"
CONN_HOST=$(expand_local_ip "$CONN_HOST") || exit 1

DEST_QUERY="${3:-~}"

SSH_ARGS=()
[[ -n "$CONN_PORT" ]] && SSH_ARGS+=("-p" "$CONN_PORT")
[[ -n "$CONN_USER" ]] && SSH_TARGET="$CONN_USER@$CONN_HOST" || SSH_TARGET="$CONN_HOST"

# --- Resolve remote path via nav-engine ---
if [[ "$DEBUG" == true ]]; then
    DEST=$(cat "$LIBDIR/shared/nav-engine.sh" | ssh "${SSH_ARGS[@]}" "$SSH_TARGET" \
        "TERM=dumb bash -s -- $NAV_FLAGS '$DEST_QUERY'") || {
        echo "yeet: failed to resolve '$DEST_QUERY' on $SSH_TARGET" >&2
        exit 1
    }
else
    DEST=$(cat "$LIBDIR/shared/nav-engine.sh" | ssh "${SSH_ARGS[@]}" "$SSH_TARGET" \
        "TERM=dumb bash -s -- $NAV_FLAGS '$DEST_QUERY'" 2>/dev/null) || {
        echo "yeet: failed to resolve '$DEST_QUERY' on $SSH_TARGET" >&2
        exit 1
    }
fi

if ! ssh "${SSH_ARGS[@]}" "$SSH_TARGET" "command -v rsync >/dev/null 2>&1"; then
    echo "yeet: rsync not found on $SSH_TARGET" >&2
    exit 1
fi

if [[ "$SKIP_CONFIRM" == false ]]; then
    if [[ ! -e "$LOCAL_SOURCE" ]]; then
        echo "yeet: source not found: $LOCAL_SOURCE" >&2
        exit 1
    fi

    echo "Yeeting:"
    echo -e "  \033[34m$LOCAL_SOURCE\033[0m"
    echo "To:"
    echo -e "  \033[1;36m$SSH_TARGET:$DEST\033[0m"
    echo
    read -rp "Y/n: " confirm
    [[ "$confirm" =~ ^[Nn] ]] && echo "Cancelled" && exit 0
    printf "\033[%dA\033[J" 5
fi

# --- Transfer ---
RSYNC_ARGS=("-az")
[[ -n "$CONN_PORT" ]] && RSYNC_ARGS+=("--rsh" "ssh -p $CONN_PORT")

RSYNC_PID=""
SUCCESS=false

cleanup() {
    [[ -n "${RSYNC_PID:-}" ]] && kill -0 "$RSYNC_PID" 2>/dev/null && {
        kill "$RSYNC_PID" 2>/dev/null
        wait "$RSYNC_PID" 2>/dev/null
    }

    if [[ -n "$TEMP_DIR" && -d "$TEMP_DIR" ]]; then
        [[ "$SUCCESS" == false ]] && mv "$TEMP_DIR"/* "$ORIGINAL_DIR/" 2>/dev/null || true
        rm -rf "$TEMP_DIR"
    fi
}
trap cleanup INT TERM EXIT

ORIGINAL_DIR=$(pwd)
TEMP_DIR=""
RSYNC_SOURCE="${LOCAL_SOURCE%/}"

if [[ "$REMOVE_SOURCE" == true ]]; then
    TEMP_DIR=$(mktemp -d)
    mv "$LOCAL_SOURCE" "$TEMP_DIR/"
    RSYNC_SOURCE="$TEMP_DIR/$(basename "$LOCAL_SOURCE")"
fi

rsync "${RSYNC_ARGS[@]}" --info=progress2 --no-inc-recursive "$RSYNC_SOURCE" "$SSH_TARGET:$DEST/"
RSYNC_EXIT=$?
# rsync "${RSYNC_ARGS[@]}" "$RSYNC_SOURCE" "$SSH_TARGET:$DEST/" 2>/dev/null &
# RSYNC_PID=$!
# spin "Yeeting" $RSYNC_PID
# wait "$RSYNC_PID"
# RSYNC_EXIT=$?

[[ $RSYNC_EXIT -ne 0 ]] && printf "\rYeet failed\n" && exit 1

SUCCESS=true
printf "\r\033[K"
printf "Yeeted \033[34m%s\033[0m\n" "$LOCAL_SOURCE"
printf " \033[1;36m→ %s:%s\033[0m\n" "$SSH_TARGET" "$DEST"
