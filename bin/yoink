#!/usr/bin/env bash
# yoink - pull files from remote machines via nav-engine

set -euo pipefail

COPY_MODE=false
SKIP_CONFIRM=false
NAV_FLAGS=""

POSITIONAL=()
for arg in "$@"; do
    case "$arg" in
        -c|--copy) COPY_MODE=true ;;
        -l|--luck) SKIP_CONFIRM=true ;;
        --log) NAV_FLAGS="--log" ;;
        -*|yeet) ;;
        *) POSITIONAL+=("$arg") ;;
    esac
done
set -- "${POSITIONAL[@]}"

if [[ $# -lt 1 ]]; then
    echo "Usage: yoink [-c] <host:source> [destination]"
    echo ""
    echo "Examples:"
    echo "  yoink nuremberg:~/file.txt           # pull to current dir"
    echo "  yoink vps:d/backup.db ~/backups      # pull to specific dir"
    echo "  yoink -c server:w/data.sql .         # copy (keep remote)"
    echo "  yoink user@host:~/logs/*.txt logs/   # specify user"
    echo ""
    echo "Options:"
    echo "  -c, --copy    Keep source on remote (default: move)"
    echo "  -l, --luck    Skip confirmation prompt"
    echo "  --log         Show nav-engine resolution debug info"
    echo ""
    echo "Resolves remote path via nav-engine."
    exit 1
fi

# First arg is host:source, optional second is local destination
REMOTE="$1"
LOCAL_DEST="${2:-.}"

# Split host:source
if [[ ! "$REMOTE" =~ : ]]; then
    echo "yoink: invalid format, expected host:source" >&2
    exit 1
fi

HOST="${REMOTE%%:*}"
REMOTE_PATH_QUERY="${REMOTE#*:}"

# If shell expanded ~ to local $HOME, convert back to ~ for remote
[[ "$REMOTE_PATH_QUERY" == "$HOME" || "$REMOTE_PATH_QUERY" == "$HOME/"* ]] && REMOTE_PATH_QUERY="~${REMOTE_PATH_QUERY#$HOME}"

# Resolve remote base path via SSH (bootstrap nav-engine)
REMOTE_PATH=$(cat "$LIBDIR/nav-engine.sh" | ssh "$HOST" "TERM=dumb bash -s -- -f '$REMOTE_PATH_QUERY'" 2>/dev/null) || {
    echo "yoink: failed to resolve '$REMOTE_PATH_QUERY' on $HOST" >&2
    exit 1
}

# Check if rsync is available on remote
if ! ssh "$HOST" "command -v rsync >/dev/null 2>&1"; then
    echo "yoink: rsync not found on $HOST" >&2
    exit 1
fi

if [[ "$SKIP_CONFIRM" == false ]]; then
    # Check if source exists on remote
    if ! ssh "$HOST" "test -e '$REMOTE_PATH'" 2>/dev/null; then
        echo "yoink: source not found on $HOST:$REMOTE_PATH" >&2
        exit 1
    fi

    echo "Yoinking:"
    echo -e "  \033[34m$REMOTE_PATH\033[0m"
    echo "From:"
    echo -e "  \033[1;36m$HOST\033[0m"
    echo "To:"
    echo -e "  \033[34m$LOCAL_DEST\033[0m"
    echo
    read -p "Y/n: " confirm

    if [[ "$confirm" =~ ^[Nn] ]]; then
        echo "Cancelled"
        exit 0
    fi

    # Clear confirmation output
    printf "\033[%dA\033[J" 6
fi

# Transfer
RSYNC_PID=""
SUCCESS=false

cleanup() {
    if [[ -n "${RSYNC_PID:-}" ]] && kill -0 "$RSYNC_PID" 2>/dev/null; then
        kill "$RSYNC_PID" 2>/dev/null
        wait "$RSYNC_PID" 2>/dev/null
    fi
}

trap cleanup INT TERM EXIT

RSYNC_FLAGS="-az"
[[ "$COPY_MODE" == false ]] && RSYNC_FLAGS="-az --remove-source-files"

printf "Yoinking"

rsync $RSYNC_FLAGS "$HOST:$REMOTE_PATH" "$LOCAL_DEST" 2>/dev/null &
RSYNC_PID=$!

DOTS=""
while kill -0 "$RSYNC_PID" 2>/dev/null; do
    printf "\rYoinking%-3s" "$DOTS"
    DOTS="${DOTS}."
    [[ ${#DOTS} -gt 3 ]] && DOTS=""
    sleep 0.3
done
wait "$RSYNC_PID"
RSYNC_EXIT=$?

if [[ $RSYNC_EXIT -ne 0 ]]; then
    printf "\rYoink failed\n"
    exit 1
fi

SUCCESS=true

# Clean final output
printf "\r\033[K"
printf "Yoinked \033[34m%s\033[0m\n" "$(basename "$REMOTE_PATH")"
printf " \033[1;36m← %s:%s\033[0m\n" "$HOST" "$REMOTE_PATH"
