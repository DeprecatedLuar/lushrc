#!/usr/bin/env bash
# yoink - pull files from remote machines

set -euo pipefail

LIBDIR="${LIBDIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/lib" && pwd)}"
source "$LIBDIR/shared/net.sh"
source "$LIBDIR/shared/spinner.sh"

REMOVE_SOURCE=false
SKIP_CONFIRM=false
NAV_FLAGS=""
CONN_USER=""
CONN_HOST=""
CONN_PORT=""
FLAG_PORT=""

POSITIONALS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --rm)           REMOVE_SOURCE=true; shift ;;
        -y|--yes)       SKIP_CONFIRM=true; shift ;;
        --log)          NAV_FLAGS="--log"; shift ;;
        -p)             FLAG_PORT="$2"; shift 2 ;;
        -l)             CONN_USER="$2"; shift 2 ;;
        -*)             echo "Unknown option: $1" >&2; exit 1 ;;
        *)              POSITIONALS+=("$1"); shift ;;
    esac
done
set -- "${POSITIONALS[@]}"

if [[ $# -lt 1 ]]; then
    echo "Usage: yoink [--rm] [-y] [-p PORT] [-l USER] [user@]host[:port] [remote_path] [local_dest]"
    echo ""
    echo "Examples:"
    echo "  yoink nuremberg                      # pull \$HOME"
    echo "  yoink .17:8022 file.txt              # pull file from LAN host"
    echo "  yoink vps d/backup.db ~/backups      # nav-engine path, local dest"
    echo "  yoink --rm server w/data.sql .       # pull and delete remote source"
    exit 1
fi

# --- Normalize host ---
local_input="$1"
if [[ "$local_input" == *@* ]]; then
    CONN_USER="${local_input%%@*}"
    local_input="${local_input#*@}"
fi
if [[ "$local_input" == *:* ]]; then
    COLON_PORT="${local_input##*:}"
    CONN_HOST="${local_input%:*}"
    if [[ -n "$FLAG_PORT" && "$FLAG_PORT" != "$COLON_PORT" ]]; then
        echo "Error: conflicting ports (-p $FLAG_PORT vs :$COLON_PORT)" >&2
        exit 1
    fi
    CONN_PORT="$COLON_PORT"
else
    CONN_HOST="$local_input"
fi
[[ -n "$FLAG_PORT" && -z "$CONN_PORT" ]] && CONN_PORT="$FLAG_PORT"
CONN_HOST=$(expand_local_ip "$CONN_HOST") || exit 1

REMOTE_PATH_QUERY="${2:-~}"
LOCAL_DEST="${3:-.}"

SSH_ARGS=()
[[ -n "$CONN_PORT" ]] && SSH_ARGS+=("-p" "$CONN_PORT")
[[ -n "$CONN_USER" ]] && SSH_TARGET="$CONN_USER@$CONN_HOST" || SSH_TARGET="$CONN_HOST"

# --- Resolve remote path via nav-engine ---
REMOTE_PATH=$(cat "$LIBDIR/shared/nav-engine.sh" | ssh "${SSH_ARGS[@]}" "$SSH_TARGET" \
    "TERM=dumb bash -s -- $NAV_FLAGS -f '$REMOTE_PATH_QUERY'" 2>/dev/null) || {
    echo "yoink: failed to resolve '$REMOTE_PATH_QUERY' on $SSH_TARGET" >&2
    exit 1
}

if ! ssh "${SSH_ARGS[@]}" "$SSH_TARGET" "command -v rsync >/dev/null 2>&1"; then
    echo "yoink: rsync not found on $SSH_TARGET" >&2
    exit 1
fi

if [[ "$SKIP_CONFIRM" == false ]]; then
    if ! ssh "${SSH_ARGS[@]}" "$SSH_TARGET" "test -e '$REMOTE_PATH'" 2>/dev/null; then
        echo "yoink: source not found on $SSH_TARGET:$REMOTE_PATH" >&2
        exit 1
    fi

    echo "Yoinking:"
    echo -e "  \033[34m$REMOTE_PATH\033[0m"
    echo "From:"
    echo -e "  \033[1;36m$SSH_TARGET\033[0m"
    echo "To:"
    echo -e "  \033[34m$LOCAL_DEST\033[0m"
    echo
    read -rp "Y/n: " confirm
    [[ "$confirm" =~ ^[Nn] ]] && echo "Cancelled" && exit 0
    printf "\033[%dA\033[J" 6
fi

# --- Transfer ---
RSYNC_ARGS=("-az")
[[ "$REMOVE_SOURCE" == true ]] && RSYNC_ARGS+=("--remove-source-files")
[[ -n "$CONN_PORT" ]] && RSYNC_ARGS+=("--rsh" "ssh -p $CONN_PORT")

RSYNC_PID=""
SUCCESS=false

cleanup() {
    [[ -n "${RSYNC_PID:-}" ]] && kill -0 "$RSYNC_PID" 2>/dev/null && {
        kill "$RSYNC_PID" 2>/dev/null
        wait "$RSYNC_PID" 2>/dev/null
    }
}
trap cleanup INT TERM EXIT

rsync "${RSYNC_ARGS[@]}" "$SSH_TARGET:$REMOTE_PATH" "$LOCAL_DEST" 2>/dev/null &
RSYNC_PID=$!
spin "Yoinking" $RSYNC_PID
wait "$RSYNC_PID"
RSYNC_EXIT=$?

[[ $RSYNC_EXIT -ne 0 ]] && printf "\rYoink failed\n" && exit 1

SUCCESS=true
printf "\r\033[K"
printf "Yoinked \033[34m%s\033[0m\n" "$(basename "$REMOTE_PATH")"
printf " \033[1;36m← %s:%s\033[0m\n" "$SSH_TARGET" "$REMOTE_PATH"
