#!/usr/bin/env bash
# ssh shadow - transparent wrapper adding:
#   --password flag   (sshpass integration)
#   .N host shorthand (LAN subnet expansion via net.sh)
#   kitten ssh        (better terminal integration when inside Kitty)

LIBDIR="${LIBDIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/lib" && pwd)}"
source "$LIBDIR/shared/net.sh"

# Handle 'unlock' subcommand - send SSH keys for password-free access
if [[ "$1" == "unlock" ]]; then
    shift
    if [[ $# -lt 1 ]]; then
        echo "Usage: lsh unlock [keyfile] <user@host[:port]> [--all]" >&2
        echo "  Auto-detects ed25519 > rsa if no keyfile given" >&2
        exit 1
    fi

    # Parse arguments
    KEYFILE=""
    SEND_ALL=false
    HOST_ARG=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --all)
                SEND_ALL=true
                shift
                ;;
            *)
                # If it looks like a file and exists, treat as keyfile
                if [[ -f "$1" ]] || [[ "$1" == *.pub ]]; then
                    KEYFILE="$1"
                    shift
                else
                    HOST_ARG="$1"
                    shift
                    break
                fi
                ;;
        esac
    done

    [[ -z "$HOST_ARG" ]] && { echo "lsh unlock: no host specified" >&2; exit 1; }

    # Determine which key(s) to send
    KEYS=()
    if $SEND_ALL; then
        mapfile -t KEYS < <(find ~/.ssh -maxdepth 1 -name "*.pub" -type f 2>/dev/null)
        [[ ${#KEYS[@]} -eq 0 ]] && { echo "lsh unlock: no public keys found in ~/.ssh/" >&2; exit 1; }
    elif [[ -n "$KEYFILE" ]]; then
        [[ ! -f "$KEYFILE" ]] && { echo "lsh unlock: key file not found: $KEYFILE" >&2; exit 1; }
        KEYS=("$KEYFILE")
    else
        # Auto-detect: ed25519 > rsa
        if [[ -f ~/.ssh/id_ed25519.pub ]]; then
            KEYS=(~/.ssh/id_ed25519.pub)
        elif [[ -f ~/.ssh/id_rsa.pub ]]; then
            KEYS=(~/.ssh/id_rsa.pub)
        else
            echo "lsh unlock: no default key found (id_ed25519.pub or id_rsa.pub)" >&2
            exit 1
        fi
    fi

    # Read key contents
    KEY_DATA=""
    for key in "${KEYS[@]}"; do
        KEY_DATA+="$(cat "$key")"$'\n'
    done

    # Send keys via SSH
    # Use the lsh wrapper itself for .N expansion and --password support
    "$0" "$HOST_ARG" "bash -c 'mkdir -p ~/.ssh && chmod 700 ~/.ssh && cat >> ~/.ssh/authorized_keys && chmod 600 ~/.ssh/authorized_keys'" <<< "$KEY_DATA"

    if [[ $? -eq 0 ]]; then
        echo "✓ Unlocked: ${KEYS[*]##*/} → $HOST_ARG"
    else
        echo "✗ Failed to unlock $HOST_ARG" >&2
        exit 1
    fi
    exit 0
fi

# Handle 'add' subcommand
if [[ "$1" == "add" ]]; then
    shift
    if [[ $# -lt 2 ]]; then
        echo "Usage: lsh add <name> <user@host[:port]> [-p port]" >&2
        exit 1
    fi

    NAME="$1"
    CONN="$2"
    shift 2

    # Parse port from -p flag or :port suffix
    PORT=""
    if [[ "$1" == "-p" && -n "$2" ]]; then
        PORT="$2"
    elif [[ "$CONN" =~ :([0-9]+)$ ]]; then
        PORT="${BASH_REMATCH[1]}"
        CONN="${CONN%:*}"
    fi

    # Parse user@host
    if [[ "$CONN" =~ ^([^@]+)@(.+)$ ]]; then
        USER="${BASH_REMATCH[1]}"
        HOST="${BASH_REMATCH[2]}"
    else
        echo "lsh: invalid format, expected user@host[:port]" >&2
        exit 1
    fi

    # Ensure ~/.ssh/config.d/ exists
    mkdir -p ~/.ssh/config.d
    chmod 700 ~/.ssh/config.d

    # Ensure Include directive exists in ~/.ssh/config
    SSH_CONFIG="$HOME/.ssh/config"
    if [[ ! -f "$SSH_CONFIG" ]]; then
        echo "Include ~/.ssh/config.d/*" > "$SSH_CONFIG"
        chmod 600 "$SSH_CONFIG"
    elif ! grep -q "^Include.*config\.d/\*" "$SSH_CONFIG"; then
        # Prepend Include directive
        TMP=$(mktemp)
        echo "Include ~/.ssh/config.d/*" > "$TMP"
        cat "$SSH_CONFIG" >> "$TMP"
        mv "$TMP" "$SSH_CONFIG"
        chmod 600 "$SSH_CONFIG"
    fi

    # Append to ~/.ssh/config.d/lsh
    LSH_CONFIG="$HOME/.ssh/config.d/lsh"
    {
        echo ""
        echo "Host $NAME"
        echo "    HostName $HOST"
        echo "    User $USER"
        [[ -n "$PORT" ]] && echo "    Port $PORT"
    } >> "$LSH_CONFIG"
    chmod 600 "$LSH_CONFIG"

    echo "Added: ssh $NAME → $USER@$HOST${PORT:+:$PORT}"
    exit 0
fi

# Find the real ssh binary (skip ourselves)
_SELF_DIR="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"
_RAW_SSH=$(type -a ssh 2>/dev/null | awk '{print $NF}' | grep -vF "$_SELF_DIR/" | head -1)
[[ -z "$_RAW_SSH" ]] && { echo "lsh: could not find system ssh" >&2; exit 1; }

# Use kitten ssh only when running inside Kitty terminal
# Disabled: kitten ssh hangs the terminal
# if [[ -n "$KITTY_WINDOW_ID" ]] && command -v kitten &>/dev/null; then
#     REAL_SSH=(kitten ssh)
# else
#     REAL_SSH=("$_RAW_SSH")
# fi
REAL_SSH=("$_RAW_SSH")

# Parse --password flag (can appear anywhere in args)
PASSWORD=""
ARGS=()
SKIP_NEXT=false

for arg in "$@"; do
    if $SKIP_NEXT; then
        PASSWORD="$arg"
        SKIP_NEXT=false
        continue
    fi
    case "$arg" in
        -P|--password) SKIP_NEXT=true ;;
        --password=*) PASSWORD="${arg#--password=}" ;;
        --raw|--escape-hatch) exec "$_RAW_SSH" "${ARGS[@]}" ;;
        --help|-h)
            cat <<'EOF'
lsh — lushrc ssh wrapper

Commands:
  lsh unlock [keyfile] <user@host[:port]> [--all]
                          Send SSH keys for password-free access
                          Auto-detects ed25519 > rsa if no keyfile given

  lsh add <name> <user@host[:port]> [-p port]
                          Save SSH config entry to ~/.ssh/config.d/lsh

Extras:
  --password, -P <pass>   Connect using sshpass (requires sshpass)
  --raw, --escape-hatch   Bypass lsh, exec system ssh directly
  .N                      LAN subnet shorthand (e.g. .17 → 192.168.1.17)
  user@.N[:port]          user + subnet + optional port

EOF
            "$_RAW_SSH" 2>&1 || true
            exit 0
            ;;
        *) ARGS+=("$arg") ;;
    esac
done

# Expand .N subnet shorthand in host argument (handles user@.N and bare .N)
for i in "${!ARGS[@]}"; do
    arg="${ARGS[$i]}"
    # Only touch non-flag args that contain .N pattern
    [[ "$arg" == -* ]] && continue
    if [[ "$arg" =~ ^([^@]+@)?(\.[0-9]+)(:[0-9]+)?$ ]]; then
        prefix="${BASH_REMATCH[1]}"
        host="${BASH_REMATCH[2]}"
        port="${BASH_REMATCH[3]#:}"  # strip leading colon
        expanded=$(expand_local_ip "$host") || exit 1
        ARGS[$i]="${prefix}${expanded}"
        [[ -n "$port" ]] && ARGS=("-p" "$port" "${ARGS[@]}")
        break  # host is always the first non-flag positional
    fi
done

if [[ -n "$PASSWORD" ]]; then
    if ! command -v sshpass &>/dev/null; then
        echo "ssh: --password requires sshpass (apt install sshpass)" >&2
        exit 1
    fi
    exec sshpass -p "$PASSWORD" "${REAL_SSH[@]}" "${ARGS[@]}"
fi

# Set up askpass only for non-interactive shells (where SSH can't prompt directly)
if [[ ! -t 0 ]]; then
    export SSH_ASKPASS="${LIBDIR}/lsh/ssh-askpass"
    export SSH_ASKPASS_REQUIRE=prefer
fi

# Client-side TERM compatibility: send universal TERM to avoid remote terminfo issues
# Modern terminals (kitty, alacritty, foot) use exotic TERM values that most servers
# lack terminfo definitions for. Override to xterm-256color which is universally supported.
case "$TERM" in
    xterm-kitty|alacritty|alacritty-direct|foot|foot-extra|wezterm)
        TERM=xterm-256color exec "${REAL_SSH[@]}" "${ARGS[@]}"
        ;;
    *)
        exec "${REAL_SSH[@]}" "${ARGS[@]}"
        ;;
esac
