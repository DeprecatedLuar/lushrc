#!/usr/bin/env bash

DOCK_DIR="${TMPDIR:-/tmp}/dock"
LIBDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/lib" && pwd)"
source "$LIBDIR/shared/net.sh"
source "$LIBDIR/shared/spinner.sh"

# --- Normalize SSH connection args ---
# Accepts: [-p PORT] [-l USER] [user@]host[:port]
# Outputs: CONN_USER, CONN_HOST, CONN_PORT

CONN_USER=""
CONN_HOST=""
CONN_PORT=""
FLAG_PORT=""
REMOTE_PATH=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -p) FLAG_PORT="$2"; shift 2 ;;
        -l) CONN_USER="$2"; shift 2 ;;
        -*) echo "Unknown option: $1"; exit 1 ;;
        *)
            if [[ -z "$CONN_HOST" ]]; then
                local_input="$1"

                # Split user@host:port
                if [[ "$local_input" == *@* ]]; then
                    CONN_USER="${local_input%%@*}"
                    local_input="${local_input#*@}"
                fi

                # Split host:port
                if [[ "$local_input" == *:* ]]; then
                    COLON_PORT="${local_input##*:}"
                    CONN_HOST="${local_input%:*}"

                    if [[ -n "$FLAG_PORT" && "$FLAG_PORT" != "$COLON_PORT" ]]; then
                        echo "Error: conflicting ports (-p $FLAG_PORT vs :$COLON_PORT)"
                        exit 1
                    fi
                    CONN_PORT="$COLON_PORT"
                else
                    CONN_HOST="$local_input"
                fi
            else
                REMOTE_PATH="$1"
            fi
            shift
            ;;
    esac
done

[[ -n "$FLAG_PORT" && -z "$CONN_PORT" ]] && CONN_PORT="$FLAG_PORT"

if [[ -z "$CONN_HOST" ]]; then
    echo "Usage: dock [-p PORT] [-l USER] [user@]host[:port] [remote_path]"
    exit 1
fi

CONN_HOST=$(expand_local_ip "$CONN_HOST") || exit 1

# --- Build SSH/SSHFS args ---
SSH_ARGS=()
[[ -n "$CONN_PORT" ]] && SSH_ARGS+=("-p" "$CONN_PORT")
[[ -n "$CONN_USER" ]] && SSH_TARGET="$CONN_USER@$CONN_HOST" || SSH_TARGET="$CONN_HOST"

printf "Docking %s..." "$CONN_HOST"

# --- Single SSH call: get home dir + hostname ---
read -r REMOTE_HOME REMOTE_NAME < <(ssh "${SSH_ARGS[@]}" "$SSH_TARGET" 'echo $HOME $(hostname -s)' 2>/dev/null)

if [[ -z "$REMOTE_HOME" ]]; then
    printf "\rCould not connect to %s\n" "$CONN_HOST"
    exit 1
fi

# Resolve mount path: explicit arg > remote $HOME
if [[ -n "$REMOTE_PATH" && "$REMOTE_PATH" != /* ]]; then
    REMOTE_PATH="$REMOTE_HOME/$REMOTE_PATH"
fi
MOUNT_PATH="${REMOTE_PATH:-$REMOTE_HOME}"

# Name: hostname[-subdir] or sanitized IP as fallback
REMOTE_NAME="${REMOTE_NAME:-${CONN_HOST//./_}}"
SUBDIR="${REMOTE_PATH:+"-$(basename "$MOUNT_PATH")"}"
MOUNT_NAME="${REMOTE_NAME}${SUBDIR}"
MOUNT_POINT="$DOCK_DIR/$MOUNT_NAME"
SYMLINK="$HOME/$MOUNT_NAME"

if mountpoint -q "$MOUNT_POINT" 2>/dev/null; then
    printf "\r%s already docked at ~/%s\n" "$CONN_HOST" "$MOUNT_NAME"
    exit 0
fi

[[ -L "$SYMLINK" && ! -e "$SYMLINK" ]] && rm "$SYMLINK"

if [[ -e "$SYMLINK" && ! -L "$SYMLINK" ]]; then
    printf "\rError: ~/%s exists and is not a symlink\n" "$MOUNT_NAME"
    exit 1
fi

mkdir -p "$DOCK_DIR" "$MOUNT_POINT"

# --- Mount ---
sshfs "${SSH_ARGS[@]}" "$SSH_TARGET:$MOUNT_PATH" "$MOUNT_POINT" \
    -o reconnect,ServerAliveInterval=15,ServerAliveCountMax=3 \
    -o follow_symlinks,auto_cache,idmap=user &

SSHFS_PID=$!
spin "Docking $CONN_HOST" $SSHFS_PID
wait $SSHFS_PID

if mountpoint -q "$MOUNT_POINT"; then
    ln -sfn "$MOUNT_POINT" "$SYMLINK"
    printf "\r%s docked at ~/%s\n" "$CONN_HOST" "$MOUNT_NAME"
else
    printf "\rDocking %s failed\n" "$CONN_HOST"
    rmdir "$MOUNT_POINT" 2>/dev/null
    exit 1
fi
