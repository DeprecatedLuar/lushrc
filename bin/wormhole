#!/usr/bin/env bash
# wormhole - Nav-engine powered symlink wrapper

if [[ "$1" == "kill" ]] || [[ "$1" == "close" ]]; then
    rm -f /tmp/wormhole ~/wormhole ~/Downloads/wormhole ~/Workspace/wormhole ~/Desktop/wormhole
    exit 0
fi

# Two-arg mode: custom symlink from source to dest
if [[ -n "$2" ]]; then
    # Resolve source to absolute path
    if [[ -e "$1" ]]; then
        source_path=$(realpath "$1")
    else
        source_path=$(~/bin/lib/nav-engine.sh "$1") || exit 1
    fi

    # Resolve destination
    dest_path=$(~/bin/lib/nav-engine.sh "$2") || exit 1

    # Determine final symlink path
    if [[ -d "$dest_path" ]]; then
        # Dest is a directory, use basename of source
        link_path="$dest_path/$(basename "$source_path")"
    else
        # Use dest path as-is (for custom naming)
        link_path="$dest_path"
    fi

    # Safety check: prevent overwriting existing files/directories
    if [[ -e "$link_path" ]] && [[ ! -L "$link_path" ]]; then
        echo "Error: $link_path already exists (not a symlink). Aborting to prevent data loss." >&2
        exit 1
    fi

    ln -sfn "$source_path" "$link_path"
    echo "$link_path → $source_path"
    exit 0
fi

# One-arg or no-arg mode: create wormholes to common locations
if [[ -z "$1" ]]; then
    target="$PWD"
else
    target=$(~/bin/lib/nav-engine.sh "$1") || exit 1
fi

# Safety check for each wormhole location
for wh_path in ~/wormhole ~/Downloads/wormhole ~/Workspace/wormhole ~/Desktop/wormhole; do
    if [[ -e "$wh_path" ]] && [[ ! -L "$wh_path" ]]; then
        echo "Error: $wh_path already exists (not a symlink). Aborting to prevent data loss." >&2
        echo "Use 'wormhole kill' to remove existing wormhole symlinks first." >&2
        exit 1
    fi
done

# Create wormholes - chain through /tmp so they auto-break on reboot
ln -sfn "$target" /tmp/wormhole
ln -sfn /tmp/wormhole ~/wormhole
ln -sfn /tmp/wormhole ~/Downloads/wormhole
ln -sfn /tmp/wormhole ~/Workspace/wormhole
ln -sfn /tmp/wormhole ~/Desktop/wormhole

echo "$target"
